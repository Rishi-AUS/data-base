using System;
using System.Collections.Generic;

public class Solution {
    public int MinOperations(string s, int k) {
        int n = s.Length;
        int initialZeros = 0;
        
        // Count initial number of zeros in the string
        foreach (char ch in s) {
            if (ch == '0') {
                initialZeros++;
            }
        }

        // Distances array initialized to a large value
        int[] dist = new int[n + 1];
        Array.Fill(dist, int.MaxValue);

        // Two SortedSets to track unvisited states for even and odd counts of zeros
        SortedSet<int>[] nodeSets = new SortedSet<int>[2];
        nodeSets[0] = new SortedSet<int>();
        nodeSets[1] = new SortedSet<int>();

        for (int i = 0; i <= n; i++) {
            nodeSets[i % 2].Add(i);
        }

        Queue<int> queue = new Queue<int>();
        queue.Enqueue(initialZeros);
        dist[initialZeros] = 0;
        nodeSets[initialZeros % 2].Remove(initialZeros);

        while (queue.Count > 0) {
            int m = queue.Dequeue();

            // Early exit if we reached 0 zeros
            if (m == 0) {
                return dist[0];
            }

            // Calculate the bounds for how many zeros 'c' we can flip
            int c1 = Math.Max(k - n + m, 0);
            int c2 = Math.Min(m, k);

            // Calculate the range of the new number of zeros [lnode, rnode]
            int lnode = m + k - 2 * c2;
            int rnode = m + k - 2 * c1;

            var currentSet = nodeSets[lnode % 2];
            
            // View a subset of the unvisited states matching the parity within [lnode, rnode]
            var view = currentSet.GetViewBetween(lnode, rnode);
            List<int> nextStates = new List<int>(view);

            foreach (int m2 in nextStates) {
                dist[m2] = dist[m] + 1;
                queue.Enqueue(m2);
                currentSet.Remove(m2); // Mark as visited by removing it from the set
            }
        }

        return dist[0] == int.MaxValue ? -1 : dist[0];
    }
}
