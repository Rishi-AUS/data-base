SELECT 
    session_id,
    user_id,
    TIMESTAMPDIFF(MINUTE, MIN(event_timestamp), MAX(event_timestamp)) AS session_duration_minutes,
    SUM(IF(event_type = 'scroll', 1, 0)) AS scroll_count
FROM 
    app_events
GROUP BY 
    session_id, 
    user_id
HAVING 
    TIMESTAMPDIFF(MINUTE, MIN(event_timestamp), MAX(event_timestamp)) > 30
    AND SUM(IF(event_type = 'scroll', 1, 0)) >= 5
    AND (SUM(IF(event_type = 'click', 1, 0)) / SUM(IF(event_type = 'scroll', 1, 0))) < 0.20
    AND SUM(IF(event_type = 'purchase', 1, 0)) = 0
ORDER BY 
    scroll_count DESC, 
    session_id ASC;
